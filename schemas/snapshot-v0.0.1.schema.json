{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stemma.local/schemas/snapshot-v0.0.1.schema.json",
  "title": "Stemma Syncthing snapshot v0.0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "captured_at", "device_id", "folders"],
  "properties": {
    "schema_version": {"const": "0.0.1"},
    "captured_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "(?:Z|[+-][0-9]{2}:[0-9]{2})$"
    },
    "device_id": {"type": "string", "minLength": 1, "pattern": ".*\\S.*"},
    "folders": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path", "mode"],
        "properties": {
          "id": {"type": "string", "minLength": 1, "pattern": ".*\\S.*"},
          "path": {"type": "string", "minLength": 1, "pattern": ".*\\S.*"},
          "mode": {
            "enum": ["sendreceive", "sendonly", "receiveonly", "receiveencrypted"]
          }
        }
      }
    }
  }
}
